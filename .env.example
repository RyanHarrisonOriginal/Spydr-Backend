# Database: use a PostgreSQL connection string. Never commit real credentials.
# Example (Neon, Supabase, etc.):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Clerk: both keys are required for @clerk/express. Get them from https://dashboard.clerk.com (API Keys).
# Use the same publishable key as the frontend (VITE_CLERK_PUBLISHABLE_KEY).
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
